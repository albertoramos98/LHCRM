PROJECT_NAME="LHCRM - Dashboard Executivo"
SECRET_KEY="super-secret-jwt-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SQLite fallback for easy local dev testing, postgresql+asyncpg://user:pass@localhost:5432/luizcrm for production PostgreSQL
DATABASE_URL="sqlite+aiosqlite:///./luizcrm.db"

FRONTEND_URL="http://localhost:3000"

# Kommo CRM API Credentials
KOMMO_SUBDOMAIN="your_subdomain"
KOMMO_CLIENT_ID="your_client_id"
KOMMO_CLIENT_SECRET="your_client_secret"
KOMMO_REDIRECT_URI="http://localhost:8000/api/integrations/kommo/callback"
KOMMO_LONG_LIVED_TOKEN="your_access_token_if_available"

CACHE_TTL_SECONDS=60
AUTO_SYNC_INTERVAL_MINUTES=5
